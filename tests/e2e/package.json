{
  "name": "stellarlend-e2e-tests",
  "version": "1.0.0",
  "description": "E2E integration tests for Oracle-Contract-API pipeline",
  "private": true,
  "scripts": {
    "test": "jest --runInBand --forceExit",
    "test:verbose": "jest --runInBand --forceExit --verbose"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.5",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/*.e2e.test.ts"
    ],
    "testTimeout": 30000,
    "globals": {
      "ts-jest": {
        "tsconfig": {
          "module": "commonjs",
          "esModuleInterop": true,
          "resolveJsonModule": true
        }
      }
    }
  }
}
